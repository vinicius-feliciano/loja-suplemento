rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PRODUTOS: leitura pública, escrita só admin autenticado
    match /produtos/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ── CONFIG: leitura pública, escrita só admin autenticado
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
